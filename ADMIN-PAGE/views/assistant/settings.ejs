<div class="card card-light" style="max-width: 680px; margin: 0 auto var(--space-8); padding: var(--space-6);">
  <div class="d-flex align-center justify-between" style="margin-bottom: var(--space-6); border-bottom: 1px solid var(--accent-border); padding-bottom: var(--space-4);">
    <div class="d-flex align-center gap-3">
      <div class="avatar" style="background-color: var(--accent-black); color: white; width: 36px; height: 36px;">
        <i class="bi bi-gear-fill" style="font-size: 18px;"></i>
      </div>
      <div>
        <h4 class="font-semibold" style="font-size: 15px; line-height: 1.2; color: var(--text-primary);">Konfigurasi Engine Asisten AI</h4>
        <span class="text-muted" style="font-size: 11px;">Sesuaikan model bahasa, API Key, dan Prompt sistem</span>
      </div>
    </div>
    <a href="/assistant" class="btn btn-secondary btn-sm" style="font-size: 11px; padding: 6px 12px; height: 30px; display: flex; align-items: center; gap: var(--space-1.5);">
      <i class="bi bi-arrow-left"></i> Kembali ke Chat
    </a>
  </div>

  <% if (query.success) { %>
    <div style="background-color: var(--status-active-bg || rgba(76, 175, 80, 0.1)); border: 1px solid var(--status-active || #4CAF50); color: var(--status-active || #4CAF50); padding: 12px 16px; border-radius: var(--radius-md); font-size: 13px; font-weight: 500; margin-bottom: var(--space-6); display: flex; align-items: center; gap: 8px;">
      <i class="bi bi-check-circle-fill"></i> <%= query.success %>
    </div>
  <% } %>

  <% if (query.error) { %>
    <div style="background-color: var(--status-cancel-bg || rgba(239, 68, 68, 0.1)); border: 1px solid var(--status-cancel || #EF4444); color: var(--status-cancel || #EF4444); padding: 12px 16px; border-radius: var(--radius-md); font-size: 13px; font-weight: 500; margin-bottom: var(--space-6); display: flex; align-items: center; gap: 8px;">
      <i class="bi bi-exclamation-triangle-fill"></i> <%= query.error %>
    </div>
  <% } %>

  <form action="/assistant/settings" method="POST" style="display: flex; flex-direction: column; gap: var(--space-5);">
    
    <!-- AI Provider -->
    <div class="form-group">
      <label class="form-label" for="ai_provider" style="font-weight: 600; font-size: 12px; margin-bottom: 6px; display: block; color: var(--text-secondary);">Provider AI</label>
      <select id="ai_provider" name="ai_provider" class="form-input" style="width: 100%; height: 42px; background-color: #FFFFFF; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px; font-size: 13px;">
        <option value="gemini" <%= settings.provider === 'gemini' ? 'selected' : '' %>>Google Gemini (Default)</option>
        <option value="openai" <%= settings.provider === 'openai' ? 'selected' : '' %>>OpenAI (GPT)</option>
        <option value="claude" <%= settings.provider === 'claude' ? 'selected' : '' %>>Anthropic Claude</option>
        <option value="ollama" <%= settings.provider === 'ollama' ? 'selected' : '' %>>Ollama (Model Lokal)</option>
      </select>
    </div>

    <!-- AI Model -->
    <div class="form-group">
      <label class="form-label" for="ai_model" style="font-weight: 600; font-size: 12px; margin-bottom: 6px; display: block; color: var(--text-secondary);">Nama Model</label>
      <input type="text" id="ai_model" name="ai_model" class="form-input" 
        value="<%= settings.model %>" 
        placeholder="Default: gemini-2.5-flash / gpt-4o / claude-3-5-sonnet-latest" 
        style="width: 100%; height: 40px; font-size: 13px; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px;">
      <small style="font-size: 11px; color: var(--text-muted); display: block; margin-top: 4px;">Biarkan kosong untuk menggunakan model bawaan ter-update dari masing-masing provider.</small>
    </div>

    <!-- API Keys (Grouped) -->
    <div style="border: 1px solid var(--accent-border); border-radius: var(--radius-md); padding: var(--space-4); background-color: #FAFAFB; display: flex; flex-direction: column; gap: var(--space-4);">
      <h5 class="font-semibold" style="font-size: 12px; color: var(--text-primary); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px;">API Keys Credential</h5>
      
      <!-- Gemini Key -->
      <div class="form-group">
        <label class="form-label" for="gemini_api_key" style="font-weight: 500; font-size: 11px; margin-bottom: 4px; display: block; color: var(--text-secondary);">Google Gemini API Key</label>
        <input type="password" id="gemini_api_key" name="gemini_api_key" class="form-input" 
          value="<%= settings.geminiKey %>" 
          style="width: 100%; height: 38px; font-size: 13px; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px;">
      </div>

      <!-- OpenAI Key -->
      <div class="form-group">
        <label class="form-label" for="openai_api_key" style="font-weight: 500; font-size: 11px; margin-bottom: 4px; display: block; color: var(--text-secondary);">OpenAI API Key</label>
        <input type="password" id="openai_api_key" name="openai_api_key" class="form-input" 
          value="<%= settings.openaiKey %>" 
          placeholder="sk-..." 
          style="width: 100%; height: 38px; font-size: 13px; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px;">
      </div>

      <!-- Claude Key -->
      <div class="form-group">
        <label class="form-label" for="anthropic_api_key" style="font-weight: 500; font-size: 11px; margin-bottom: 4px; display: block; color: var(--text-secondary);">Anthropic Claude API Key</label>
        <input type="password" id="anthropic_api_key" name="anthropic_api_key" class="form-input" 
          value="<%= settings.claudeKey %>" 
          style="width: 100%; height: 38px; font-size: 13px; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px;">
      </div>
    </div>

    <!-- System Instruction Prompt -->
    <div class="form-group">
      <label class="form-label" for="system_prompt" style="font-weight: 600; font-size: 12px; margin-bottom: 6px; display: block; color: var(--text-secondary);">Instruksi Sistem (System Prompt)</label>
      <textarea id="system_prompt" name="system_prompt" class="form-input" rows="4" 
        style="width: 100%; font-size: 13px; border: 1.5px solid var(--accent-border); border-radius: var(--radius-md); padding: 8px 12px; line-height: 1.5; resize: vertical;"><%= settings.systemPrompt %></textarea>
      <small style="font-size: 11px; color: var(--text-muted); display: block; margin-top: 4px;">Instruksi dasar untuk memandu kepribadian dan format respon Asisten AI.</small>
    </div>

    <!-- Submit Action -->
    <div class="d-flex justify-end gap-3" style="border-top: 1px solid var(--accent-border); padding-top: var(--space-4); margin-top: var(--space-2);">
      <a href="/assistant" class="btn btn-secondary" style="height: 42px; display: flex; align-items: center; justify-content: center; font-size: 13px; padding: 0 20px;">Batal</a>
      <button type="submit" class="btn btn-primary" style="height: 42px; display: flex; align-items: center; justify-content: center; font-size: 13px; padding: 0 20px; font-weight: 600; box-shadow: none;">
        <i class="bi bi-save2-fill" style="margin-right: 6px;"></i> Simpan Pengaturan
      </button>
    </div>

  </form>
</div>
